    "Drag the box - or its corners - on the video above to set the crop region.": {},
    "Drag-and-drop converter between common picture formats (PNG, JPEG, HEIC, TIFF, GIF, AVIF, ICO, BMP, ICNS, JP2).": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag-and-Drop-Konverter zwischen gängigen Bildformaten (PNG, JPEG, HEIC, TIFF, GIF, AVIF, ICO, BMP, ICNS, JP2)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conversor por arrastrar y soltar entre formatos de imagen comunes (PNG, JPEG, HEIC, TIFF, GIF, AVIF, ICO, BMP, ICNS, JP2)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Convertisseur par glisser-déposer entre les formats d'image courants (PNG, JPEG, HEIC, TIFF, GIF, AVIF, ICO, BMP, ICNS, JP2)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Конвертер изображений с поддержкой перетаскивания (PNG, JPEG, HEIC, TIFF, GIF, AVIF, ICO, BMP, ICNS, JP2)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖拽即可在常见图片格式之间转换 (PNG、JPEG、HEIC、TIFF、GIF、AVIF、ICO、BMP、ICNS、JP2)。"
          }
        }
      }
    },
    "Drop %@ files here": {},
    "Drop an image to crop, rotate, resize, recolor, watermark, or remove the background.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege ein Bild ab, um es zuzuschneiden, zu drehen, zu skalieren, einzufärben, mit Wasserzeichen zu versehen oder den Hintergrund zu entfernen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra una imagen para recortar, rotar, redimensionar, retocar, marcar o quitar el fondo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déposez une image pour la rogner, la pivoter, la redimensionner, la retoucher, ajouter un filigrane ou supprimer l'arrière-plan."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите изображение, чтобы обрезать, повернуть, изменить размер, перекрасить, добавить водяной знак или удалить фон."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入图片即可裁剪、旋转、缩放、调色、加水印或抠除背景。"
          }
        }
      }
    },
