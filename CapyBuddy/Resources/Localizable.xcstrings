    "Hold Space": {},
    "Hold Space and tap a key to instantly launch or focus your most-used apps.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halten Sie die Leertaste gedrückt und drücken Sie eine Taste, um Ihre häufigsten Apps sofort zu starten oder zu fokussieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén Espacio y pulsa una tecla para abrir o enfocar al instante tus apps más usadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
