    "Adding a logo forces high error correction so scanners can recover.": {},
    "Adds a menu-bar status item showing live CPU, memory, and other system stats.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügt in der Menüleiste eine Anzeige für CPU-, Speicher- und andere Systemwerte in Echtzeit hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un elemento en la barra de menús con CPU, memoria y otras estadísticas en vivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute un indicateur dans la barre des menus avec CPU, mémoire et autres statistiques en direct."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляет в строке меню индикатор с показателями ЦП, памяти и другими данными в реальном времени."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在菜单栏添加一个实时显示 CPU、内存等系统状态的小图标。"
          }
        }
      }
    },
