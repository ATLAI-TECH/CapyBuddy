    "Capture a region of the screen with a global hotkey, then annotate, copy, save, or pin it.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfassen Sie einen Bildschirmbereich per globalem Shortcut und versehen Sie ihn mit Anmerkungen, kopieren, speichern oder anheften."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura una región de la pantalla con un atajo global; luego anótala, cópiala, guárdala o ánclala."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capturez une zone de l'écran avec un raccourci global, puis annotez-la, copiez-la, enregistrez-la ou épinglez-la."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделайте снимок области экрана глобальным сочетанием клавиш, затем добавьте аннотации, скопируйте, сохраните или прикрепите."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用全局快捷键截取屏幕区域，然后标注、复制、保存或钉到桌面。"
          }
        }
      }
    },
